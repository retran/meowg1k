// mockCommandNameReader is a mock implementation of CommandNameReader for testing.
type mockCommandNameReader struct {
	err         error
	commandName string
}

func (m *mockCommandNameReader) GetCommandName() (string, error) {
	if m.err != nil {
		return "", m.err
	}
	return m.commandName, nil
}

